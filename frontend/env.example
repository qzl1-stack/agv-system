# 前端环境变量示例
# - 开发环境：影响 vite devserver 代理（/api -> 后端）
# - 生产构建：默认仍使用相对路径 /api（由 Nginx 反代到后端）

# 后端 API 地址（仅用于开发代理）
VITE_API_TARGET=http://47.105.118.142:3000

# 流媒体/摄像头服务地址（前端组件里会用到；后续迁移只改这里）
VITE_MEDIA_HOST=47.105.118.142
VITE_CAMERA_HTTP_PORT=9090
VITE_MEDIAMTX_HLS_PORT=8888
VITE_MEDIAMTX_WHEP_PORT=8889


