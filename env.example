# Docker Compose 根目录 env 文件示例
# 复制此文件为 .env，然后修改对应的值

# ==================== 必填项 ====================

# 新服务器的公网 IP（重要！影响后端日志和前端流媒体地址）
PUBLIC_IP=34.67.207.224

# ==================== 可选项（通常不需要改） ====================

# Redis 配置（容器内网通信，一般不改）
REDIS_HOST=redis
REDIS_PORT=6379

# 前端 API 代理目标（容器内网通信）
VITE_API_TARGET=http://backend:3000

# 流媒体服务地址（从前端客户端角度，改成 PUBLIC_IP）
VITE_MEDIA_HOST=${PUBLIC_IP}

# ==================== 迁移步骤 ====================
# 1. 复制此文件: cp env.example .env
# 2. 编辑 .env，改 PUBLIC_IP 为新服务器IP
# 3. 运行: docker-compose up -d --build
# 4. 验证: docker-compose ps

