# 创建适用于AGV系统的.gitignore
cat > .gitignore << 'EOF'
# 依赖和包管理
node_modules/
.npm/
.yarn/
.pnpm/
package-lock.json
yarn.lock
pnpm-lock.yaml

# 环境变量和配置
.env
.env.local
.env.production
.env.development
.env.test
.env.staging
*.env
config/local.yaml
config/development.yaml

# SSH和密钥文件（绝对不能提交！）
id_rsa
id_rsa.pub
github_key
github_key.pub
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert

# IDE和编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 临时文件
tmp/
temp/
*.tmp
*.temp
*.log

# 编译输出
dist/
build/
out/
target/
bin/
obj/
*.exe
*.dll
*.so
*.dylib

# 数据库和存储
*.db
*.sqlite
*.sqlite3
*.mdb
data/
storage/
uploads/

# 文档生成
docs/_build/
_site/

# 测试和覆盖率
coverage/
.nyc_output/
*.lcov

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
docker-compose.yml
docker-data/

# 大文件和缓存（特别重要！）
.cursor-server/
.vscode-server/
.history/
.cache/
*.zip
*.tar.gz
*.rar

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# 你的AGV系统特定文件
# 添加你的项目特有的需要忽略的文件
EOF